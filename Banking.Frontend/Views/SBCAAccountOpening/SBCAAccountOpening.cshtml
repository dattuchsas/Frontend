                                    Cheque Book
                                </label>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-2">
                       
                            <label asp-for="OperatingInstrs" class="form-label">Oper. Instrs.</label>
                            <select asp-for="OperatingInstrs" asp-items="@Model.OperatingInstrsList" class="form-select"></select>
                    </div>
                    <div class="col-sm-6 col-lg-9 col-xl-4">
                       
                            <label asp-for="OperatedBy" class="form-label">Oper. by</label>
                            <input asp-for="OperatedBy" type="text" class="form-control">
                    </div>
                    <div class="col-sm-6 col-lg-3 col-xl-2">
                      
                            <label asp-for="Status" class="form-label">Status</label>
                            <input asp-for="Status" type="text" class="form-control">
                    </div>
                    <div class="col-md-6 col-lg-9 col-xl-4">
                       
                            <label asp-for="Remarks" class="form-label">Remarks</label>
                            <input asp-for="Remarks" type="text" class="form-control">
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">TDS Options</label>
                        <div>
                            <div class="form-check form-check-inline">
                    
                                    <input asp-for="TDSOptions" class="form-check-input module-checkbox" type="radio" value="TDS">
                                    <label asp-for="TDSOptions" class="form-check-label">TDS</label>
                            </div>
                            <div class="form-check form-check-inline">
                               
                                    <input asp-for="TDSOptions" class="form-check-input module-checkbox" type="radio" value="FORM15H">
                                    <label asp-for="TDSOptions" class="form-check-label">FORM15H</label>
                            </div>
                            <div class="form-check form-check-inline">
                              
                                    <input asp-for="TDSOptions" class="form-check-input module-checkbox" type="radio" value="FORM15G">
                                    <label asp-for="TDSOptions" class="form-check-label">FORM15G</label>
                            </div>
                            <div class="form-radio form-check-inline">
                             
                                    <input asp-for="TDSOptions" class="form-check-input module-checkbox" type="radio" value="NONTDS" checked >
                                    <label asp-for="TDSOptions" class="form-check-label">NONTDS</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 col-xl-2">
                      
                            <label asp-for="Panno" class="form-label">Pan No</label>
                            <input asp-for="Panno" type="text" class="form-control">
                    </div>
                    <div class="col-sm-6 col-lg-3 col-xl-2">
                                                 
                            <input asp-for="Status1" type="text" class="form-control">
                          
                    </div> 
                    <div class="col-sm-6 col-lg-3 col-xl-2">
                       
                            <label asp-for="Regno" class="form-label">Reg. No</label>
                            <input asp-for="Regno" type="text" class="form-control">
                    </div>
                    <div class="col-sm-6 col-lg-3 col-xl-4">
                     
                            <label asp-for="Regplace" class="form-label">Reg. Place</label>
