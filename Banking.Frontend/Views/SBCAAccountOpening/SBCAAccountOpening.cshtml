@model Banking.Models.SBCAAccountOpeningModel 
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script asp-append-version="true" src="~/js/app/newcustomer.js"></script>
<form class="login-form" id="SBCAAccountOpening" novalidate asp-area="" asp-controller="SBCAAccountOpening" asp-action="NewAccountOpening" asp-antiforgery="true" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
<div class="card mb-2">
    <div class="card-header">
        <div class="d-flex align-items-center flex-wrap">
            <h3 class="mb-0 section-title me-auto">Saving Account Opening </h3>
            <div class="ms-auto">
                <!-- Button trigger modal -->
             @*    <div class="btn-group" role="group" aria-label="Basic outlined example">
                        <a href="#" target="_self" class="btn btn-sm btn-outline-primary" id="newsbcaaccount">New</a>
                        <a href="#" target="_self" class="btn btn-sm btn-outline-primary" id="modifysbcaaccount">Modify</a>
                        <a href="#" target="_self" class="btn btn-sm btn-outline-primary" id="viewsbcaaccount">View</a>

                </div> *@
                    <div>
                        <div class="form-check form-check-inline">

                            <input asp-for="ModeOptions" class="form-check-input module-checkbox" type="radio" value="New" checked >
                            <label asp-for="ModeOptions" class="form-check-label">New</label>
                        </div>
                        <div class="form-check form-check-inline">

                            <input asp-for="ModeOptions" class="form-check-input module-checkbox" type="radio" value="Modify">
                            <label asp-for="ModeOptions" class="form-check-label">Modify</label>
                        </div>
                        <div class="form-check form-check-inline">

                            <input asp-for="ModeOptions" class="form-check-input module-checkbox" type="radio" value="View">
                            <label asp-for="ModeOptions" class="form-check-label">View</label>
                        </div>

                    </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="card mb-3">
            <div class="card-body">
                <div class="row align-items-end g-3">
                    <div class="col-md-6 col-lg-4 col-xl-3">
                      
                        <label asp-for="Branch" class="form-label">Branch Code</label>
                        <select asp-for="Branch" asp-items="@Model.BranchList" class="form-select"></select>
                    </div>
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                            <label asp-for="Module" class="form-label">Module ID</label>
                            <select asp-for="Module" asp-items="@Model.ModuleList" class="form-select"></select>
                    </div>
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                            <label asp-for="AccountType" class="form-label">Acc. Type</label>
                            <select asp-for="AccountType" asp-items="@Model.AccountTypeList" class="form-select"></select>
                    </div>
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                            <label asp-for="AccountNumber" class="form-label">Acc. No</label>
                            <select asp-for="AccountNumber" asp-items="@Model.AccountNumberList" class="form-select"></select>
                              
                    </div>
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                            <label asp-for="Tranno" class="form-label">Tran No</label>
                            <select asp-for="Tranno" asp-items="@Model.TrannoList" class="form-select"></select>
                    </div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row align-items-end g-3">
                    <div class="col-md-6 col-lg-5 col-xl-4 col-xxl-3">
                            <label asp-for="CustomerId" class="form-label">Cust. ID</label>
                     
