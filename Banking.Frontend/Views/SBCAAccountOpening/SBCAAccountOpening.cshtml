                                <input asp-for="OpeningDate" type="text" class="form-control">
                                <div class="input-group-addon input-group-text">
                                    <img src="~/images/datepicker_icon.svg" width="24">
                                </div>
                            </div>
                    </div>
                    <div class="col-lg-6 col-xl-12">
                        <div class="form-check form-check-inline mb-2">
                                <input asp-for="CheckMinor" class="form-check-input" type="checkbox">
                                <label asp-for="CheckMinor" class="form-check-label">
                                    Minor (Y/N)
                                </label>
                        </div>
                        <div class="form-check form-check-inline mb-2">
                                <input asp-for="CheckBankStaff" class="form-check-input" type="checkbox">
                                <label asp-for="CheckBankStaff" class="form-check-label">
