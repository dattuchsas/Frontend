@using Banking.Models
@model Banking.Models.TransferTransactionModel
@{
    Layout = "_Layout";
}

<div class="card h-100">
    <div class="card-header">
        <h3 class="mb-0 section-title">Transfers</h3>
    </div>
    <div class="card-body pt-2">
        <div class="d-flex flex-wrap bg-light px-2 pt-2 mb-2 border rounded">
            <div class="me-3 fw-bold">
                @foreach (TransactionModes mode in Enum.GetValues(typeof(TransactionModes)))
                {
                    <div class="form-check form-check-inline" id="@mode">
                        <input asp-for="TransactionMode" type="radio" class="form-check-input module-checkbox" value="@mode" />
                        <label asp-for="TransactionMode" class="form-check-label">@mode</label>
                    </div>
                }
            </div>
            <div class="ms-auto">
                <div class="form-check form-check-inline">
                    <input asp-for="CheckABB" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckABB" class="form-check-label">ABB</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckCheque" class="form-check-input module-checkbox" type="checkbox">
                    <label asp-for="CheckCheque" class="form-check-label">Cheque</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckLinkModule" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckLinkModule" class="form-check-label">Link Module</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckTransDetails" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckTransDetails" class="form-check-label">Trans Details</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckDenoms" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckDenoms" class="form-check-label">Denoms</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckRateDetails" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckRateDetails" class="form-check-label">Rate Details</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="CheckDenomsTally" class="form-check-input module-checkbox" type="checkbox" />
                    <label asp-for="CheckDenomsTally" class="form-check-label">Denom Tally</label>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col">
                <div class="row align-items-end gx-3 gy-2">
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="Branch" class="form-label">Branch Code</label>
                        <select asp-for="Branch" asp-items="@Model.BranchList" class="form-select"></select>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="ServiceCode" class="form-label">Service Id</label>
                        <select asp-for="ServiceCode" asp-items="@Model.ServiceList" class="form-select"></select>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="ModuleCode" class="form-label">Module ID</label>
                        <select asp-for="ModuleCode" asp-items="@Model.ModuleList" class="form-select"></select>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="GLCode" class="form-label">GL Code</label>
                        <select asp-for="GLCode" asp-items="@Model.GLCodeList" class="form-select"></select>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3 d-none" id="categoryCodeList">
                        <label asp-for="CategoryCode" class="form-label">Category Code</label>
                        <select asp-for="CategoryCode" asp-items="@Model.CategoryList" class="form-select"></select>
                    </div>
                    <div class="col-md-4 col-lg-3 col-xl-3">
                        <label asp-for="AccountNumber" class="form-label">Account Number<span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="AccountNumber" type="text" class="form-control" />
                            <button class="btn btn-sm btn-primary" type="button" id="accountNumberSearch"><i class="bi bi-search"></i></button>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-4 col-xl-4">
                        <label class="form-label">Name</label>
                        <div class="input-group">
                            <input asp-for="CustomerName" type="text" class="form-control" readonly />
                            <a href="Account-Details.html" target="_blank" class="btn btn-sm btn-primary"
                               type="button">D</a>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="EffectiveDate" class="form-label">Effective Date</label>
                        <div class="input-group date" data-provide="datepicker">
                            <input asp-for="EffectiveDate" type="text" class="form-control">
                            <div class="input-group-addon input-group-text">
                                <img src="~/images/datepicker_icon.svg" width="24">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3 col-xl-3">
                        <label asp-for="Amount" class="form-label">Amount <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="Amount" type="text" class="form-control text-end" />
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#TDSBackdrop">TDS</button>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-4 col-xl-4">
                        <label asp-for="Narration" class="form-label">Narration</label>
                        <input asp-for="Narration" type="text" class="form-control" />
                    </div>
                    <div class="col-md-2 col-lg-2 col-xl-2">
                        <button id="okBtn" class="btn btn-w-auto btn-primary">Ok</button>
                        <button id="clearBtn" class="btn btn-w-auto btn-primary">Clear</button>
                    </div>
                </div>
            </div>
            <div class="phot-sign">
                <div class="border rounded">
                    <div class="photo">
                        <img id="CustomerPhoto" class="img-fluid rounded-top" />
                    </div>
                    <div class="sign border-top">
                        <img id="CustomerSign" class="img-fluid rounded-bottom" />
                    </div>
                </div>
            </div>
        </div>
        <!--Cheque Details-->
        <div id="chequeDetails" class="d-none">
            <hr />
            <div class="row gx-3 gy-2">
                <div class="col-sm-6 col-md-3 col-xl-2">
                    <label class="form-label">Check Type</label>
                    <select class="form-select" readonly="">
                        <option selected="">Select</option>
                    </select>
                </div>
                <div class="col-sm-6 col-md-3 col-xl-2">
                    <label asp-for="ChequeNo" class="form-label">Cheque No</label>
                    <input asp-for="ChequeNo" type="text" class="form-control">
                </div>
                <div class="col-sm-6 col-md-3 col-xl-2">
                    <label asp-for="ChequeDate" class="form-label">Cheque Dt.</label>
                    <input asp-for="ChequeDate" type="date" class="form-control">
                </div>
                <div class="col-sm-6 col-md-3 col-xl-2">
                    <label asp-for="ChequeFavouring" class="form-label">Cheque Fav.</label>
                    <input asp-for="ChequeFavouring" type="text" class="form-control">
                </div>
            </div>
        </div>
        <hr />
        <!--Search Selections Details-->
