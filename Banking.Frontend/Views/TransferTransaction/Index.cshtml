                    <select asp-for="REMBank" asp-items="@Model.REMBankList" class="form-select"></select>
                </div>
                <div class="col-sm-6  col-lg-3 col-xl-2 d-none Remm_IssuedOnBranch">
                    <label asp-for="REMBranch" class="form-label">Issued on Branch</label>
                    <select asp-for="REMBranch" asp-items="@Model.REMBranchList" class="form-select"></select>
