        <!--Remittence Selections Details-->
        <div class="service-box d-none" id="rem">
            <div class="row align-items-end gx-3 gy-2">
                <div class="col-sm-6  col-lg-3 col-xl-2">
                    <label class="form-label">Issued on Bank</label>
                    <select class="form-select">
                        <option selected="">101 - The Maharaja Coop</option>
                    </select>
                </div>
                <div class="col-sm-6  col-lg-3 col-xl-2">
                    <label for="Cust-Type" class="form-label">Issued on Branch</label>
