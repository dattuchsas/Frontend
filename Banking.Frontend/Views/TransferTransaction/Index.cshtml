        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 gx-3 gy-2">
            <div class="col">
                <label asp-for="DebitTransactions" class="form-label">Dr. Transactions</label>
                <div class="text-danger">@Model.DebitTransactions</div>
            </div>
            <div class="col">
                <label asp-for="CreditTransactions" class="form-label">Cr. Transactions</label>
                <div>@Model.CreditTransactions</div>
