        <!--Batch Details-->
        <div class="table-responsive mt-3">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Batch No</th>
                        <th>Tran No</th>
                        <th>GL Code</th>
                        <th>GL Description</th>
                        <th>Acc No</th>
                        <th>Name</th>
